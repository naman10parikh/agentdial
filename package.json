{
  "name": "agentdial",
  "version": "1.1.1",
  "description": "Dial your AI agent into every platform. One identity. Every channel.",
  "type": "module",
  "bin": {
    "agentdial": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "agent",
    "identity",
    "protocol",
    "telegram",
    "discord",
    "slack",
    "whatsapp",
    "sms",
    "voice",
    "twilio",
    "claude",
    "mcp",
    "multi-channel",
    "cli",
    "developer-tools"
  ],
  "author": "Naman Parikh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/naman10parikh/agentdial.git"
  },
  "homepage": "https://github.com/naman10parikh/agentdial",
  "bugs": {
    "url": "https://github.com/naman10parikh/agentdial/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "yaml": "^2.8.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "twilio": ">=4.0.0",
    "discord.js": ">=14.0.0",
    "@slack/socket-mode": ">=2.0.0",
    "@slack/web-api": ">=7.0.0",
    "node-telegram-bot-api": ">=0.60.0",
    "@sendgrid/mail": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "twilio": {
      "optional": true
    },
    "discord.js": {
      "optional": true
    },
    "@slack/socket-mode": {
      "optional": true
    },
    "@slack/web-api": {
      "optional": true
    },
    "node-telegram-bot-api": {
      "optional": true
    },
    "@sendgrid/mail": {
      "optional": true
    }
  }
}
